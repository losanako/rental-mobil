# =============================================================================
# Contoh konfigurasi .env untuk PRODUKSI di AWS Lightsail (Ubuntu + Nginx + SQLite).
# Cara pakai di server:
#   cp .env.production.example .env
#   # edit APP_URL sesuai IP/domain, lalu:
#   php artisan key:generate     (otomatis dijalankan deploy/deploy.sh jika APP_KEY kosong)
# =============================================================================

APP_NAME="Rental Mobil API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://GANTI_DENGAN_IP_LIGHTSAIL

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Kurangi noise log di produksi
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database SQLite (file disimpan di database/database.sqlite)
DB_CONNECTION=sqlite
# DB_DATABASE dibiarkan default -> database_path('database.sqlite')

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
